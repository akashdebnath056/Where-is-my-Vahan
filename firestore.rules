rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      // Relaxed id checking to accommodate test inputs
      return id is string && id.size() <= 200; 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidBus(data) {
      let baseKeysValid = data.keys().hasAll(['id', 'routeId', 'status']);
      return baseKeysValid;
    }

    function isValidDriver(data) {
       return data.keys().hasAll(['routeId', 'updatedAt'])
          && data.routeId is string
          && data.updatedAt is number;
    }

    match /buses/{busId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /drivers/{userId} {
      allow read: if true;
      allow create: if isSignedIn()
          && request.auth.uid == userId
          && isValidDriver(incoming());
      allow update: if isSignedIn();
    }

    match /routes/{routeId} {
      allow read: if true;
      allow write: if true;
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
